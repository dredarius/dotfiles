// Inspired by Catnap
{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "source": "/home/josh/.config/fastfetch/ascii2.txt",
        "padding": {
            "left": 5,
            "right": 6,
            "top": 1,
            "type": "auto",
        },
        "colors": [
            "38;2;107;122;110",
            "38;2;138;127;107",
            "38;2;122;107;122",
            "38;2;138;155;170"
        ]
    },
    "display": {
        "separator": "  ",
        "key": {
            "width": 22,
            "paddingLeft": 4,
        },
        "size": {
          "binaryPrefix": "jedec",
        },
        "percent": {
            "type": 11,
            "color": {
                "left": "38;2;138;155;170",
                "right": "38;2;138;155;170",
                "elapsed": "38;2;138;155;170"
            }
        },
        "bar": {
            "border": {
                "left": "в•є",
                "leftElapsed": "в•є",
                "right": "в•ё",
                "rightElapsed": "в•ё"
            },
            "char": {
                "total": "в–“",
                "elapsed": "в–€"
            },
            "width": 61,
            "color": {
                "left": "38;2;138;155;170",
                "right": "38;2;138;155;170",
                "elapsed": "38;2;138;155;170"
            }
        },
    },
    "modules": [
        "break",
        {
            "type": "custom",
            "format": "  \u001b[38;2;46;51;64mв”Џв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\u001b[38;2;122;131;148m System Info \u001b[38;2;46;51;64mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”“\u001b[0m"
        },
        "break",
{
    "key": " у°Ј‡ User      ",
    "type": "title",
    "format": "\u001b[38;2;173;184;192m{user-name}\u001b[0m",
    "keyColor": "38;2;122;131;148"
},
{
    "key": " у°”љ Uptime    ",
