    "format": "\u001b[38;2;173;184;192m{uptime}\u001b[0m",
    "keyColor": "38;2;122;131;148"
},
{
    "key": " оњ’ OS        ",
    "type": "os",
    "format": "\u001b[38;2;173;184;192m{name} {version}\u001b[0m",
    "keyColor": "38;2;122;131;148"
},
{
    "key": " у°Њў Kernel    ",
    "type": "kernel",
    "format": "\u001b[38;2;173;184;192m{release}\u001b[0m",
    "keyColor": "38;2;122;131;148"
},
{
    "key": " у°»  Arch      ",
    "type": "os",
    "format": "\u001b[38;2;173;184;192m{arch}\u001b[0m",
    "keyColor": "38;2;122;131;148"
},
{
    "key": " у°†Ќ Terminal  ",
